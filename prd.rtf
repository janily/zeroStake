\f3\b0\fs26 \cf0 import \{ ethers \} from "ethers";\
import \{ stakeAbi \} from "@/contracts/stakeAbi";\
import \{ STAKE_ADDRESS \} from "@/contracts/addresses";\
\
export function getEthereum() \{\
  if (typeof window === "undefined") return null;\
  return window.ethereum;\
\}\
\
export async function getBrowserProvider() \{\
  const ethereum = getEthereum();\
  if (!ethereum) \{\
    throw new Error("Wallet not found");\
  \}\
\
  return new ethers.BrowserProvider(ethereum);\
\}\
\
export async function getSigner() \{\
  const provider = await getBrowserProvider();\
  return provider.getSigner();\
\}\
\
export function getStakeContract(runner: ethers.ContractRunner) \{\
  return new ethers.Contract(STAKE_ADDRESS, stakeAbi, runner);\
\}\
