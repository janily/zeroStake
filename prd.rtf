\f3\b0\fs26 \cf0 async function loadStakeData(account: string) \{\
  const ethPid = await stakeContract.ETH_PID();\
  const poolInfo = await stakeContract.pool(ethPid);\
  const stakingBalance = await stakeContract.stakingBalance(ethPid, account);\
  const pendingReward = await stakeContract.pendingMetaNode(ethPid, account);\
  const [requestAmount, pendingWithdrawAmount] =\
    await stakeContract.withdrawAmount(ethPid, account);\
\
  return \{\
    ethPid,\
    poolInfo,\
    stakingBalance,\
    pendingReward,\
    requestAmount,\
    pendingWithdrawAmount,\
  \};\
\}\
